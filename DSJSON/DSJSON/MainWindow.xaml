<Window x:Class="DSJSON.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt Designer Pro"
        Height="900" Width="1300"
        MinHeight="600" MinWidth="900"
        WindowState="Normal"
        Background="#0D0D0F"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- SCROLLBAR -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2E2E35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="#00BFFF"/>
            <Setter Property="SelectionBrush" Value="#00BFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#00BFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- COMBOBOX -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#FF098C90"/>
            <Setter Property="BorderBrush" Value="#2E2E35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <!-- COMBOBOXITEM -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,6"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A32"/>
                    <Setter Property="Foreground" Value="#FF817676"/>
                </Trigger>

                <!-- Selected -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF1AC630"/>
                    <Setter Property="Foreground" Value="#FF196BBE"/>
                </Trigger>

            </Style.Triggers>
        </Style>

        <!-- CHECKBOX -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- LABEL -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#6B6B80"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>

        </Style>

        <!-- TOOLBOX BUTTON -->
        <Style x:Key="ToolboxBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#C0C0D0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A32"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00BFFF22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACTION BUTTON -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="BorderBrush" Value="#2E2E35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A32"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#00BFFF55"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00BFFF18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#FF6B6B33"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="270"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ TOOLBOX ═══ -->
        <Border Grid.Column="0" Background="#13131A">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Padding="16,18,16,12"
                        BorderBrush="#1E1E28"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬡" Foreground="#00BFFF" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Toolbox" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <StackPanel Margin="12,10,12,12">

                    <!-- Section: Elements -->
                    <TextBlock Text="ELEMENTS" Style="{StaticResource LabelStyle}"/>

                    <Button Tag="Text" Style="{StaticResource ToolboxBtn}"
                            PreviewMouseDown="Toolbox_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" Background="#00BFFF18"
                                    CornerRadius="6" Margin="0,0,10,0">
                                <TextBlock Text="T" Foreground="#00BFFF"
                                           FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Text" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Image" Style="{StaticResource ToolboxBtn}"
                            PreviewMouseDown="Toolbox_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" Background="#A78BFA18"
                                    CornerRadius="6" Margin="0,0,10,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE91B;"
                                           Foreground="#A78BFA" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Image" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Line" Style="{StaticResource ToolboxBtn}"
                            PreviewMouseDown="Toolbox_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" Background="#34D39918"
                                    CornerRadius="6" Margin="0,0,10,0">
                                <TextBlock Text="—" Foreground="#34D399"
                                           FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Line" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Barcode" Style="{StaticResource ToolboxBtn}"
                            PreviewMouseDown="Toolbox_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" Background="#FBBF2418"
                                    CornerRadius="6" Margin="0,0,10,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;"
                                           Foreground="#FBBF24" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Barcode" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="QR" Style="{StaticResource ToolboxBtn}"
                            PreviewMouseDown="Toolbox_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" Background="#F4725418"
                                    CornerRadius="6" Margin="0,0,10,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9F9;"
                                           Foreground="#F47254" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="QR Code" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- Divider -->
                    <Border Height="1" Background="#1E1E28" Margin="0,12"/>

                    <!-- Section: File -->
                    <TextBlock Text="FILE" Style="{StaticResource LabelStyle}"/>

                    <Button Style="{StaticResource ActionBtn}" Click="ImportJson_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;"
                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Import JSON" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Style="{StaticResource ActionBtn}" Click="ExportJson_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;"
                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Export JSON" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <TextBlock Text="HISTORY" Style="{StaticResource LabelStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnUndo" Grid.Column="0"
            Style="{StaticResource ActionBtn}"
            IsEnabled="False"
            Click="BtnUndo_Click"
            ToolTip="Ctrl+Z">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7A7;"
                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Undo" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>

                        <Button x:Name="btnRedo" Grid.Column="2"
            Style="{StaticResource ActionBtn}"
            IsEnabled="False"
            Click="BtnRedo_Click"
            ToolTip="Ctrl+Y">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7A6;"
                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Redo" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>

                    </Grid>
                    <Button Style="{StaticResource ActionBtn}"
        Click="BtnDuplicate_Click"
        ToolTip="Ctrl+D">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                       Text="&#xE8C8;"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"/>
                                <TextBlock Text="Duplicate"
                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Style="{StaticResource DangerBtn}" Click="ClearCanvas_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;"
                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Clear All" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ CANVAS ═══ -->

        <Border Grid.Column="1" Background="#1A1A20">
            <DockPanel>

                <!-- ZOOM BAR -->
                <Border DockPanel.Dock="Top" Background="#0D0D12"
                        Padding="12,7" BorderBrush="#1E1E28" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Button x:Name="btnZoomOut" Content="−" Click="ZoomOut_Click"
                                Style="{StaticResource ActionBtn}"
                                Width="28" Height="28" Padding="0" Margin="0,0,6,0"
                                FontSize="16" FontWeight="Bold" ToolTip="Zoom Out"/>

                        <Slider x:Name="zoomSlider" Minimum="10" Maximum="300" Value="100"
                                Width="160" VerticalAlignment="Center" Margin="0,0,6,0"
                                ValueChanged="ZoomSlider_ValueChanged"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>

                        <Button x:Name="btnZoomIn" Content="+" Click="ZoomIn_Click"
                                Style="{StaticResource ActionBtn}"
                                Width="28" Height="28" Padding="0" Margin="0,0,10,0"
                                FontSize="16" FontWeight="Bold" ToolTip="Zoom In"/>

                        <TextBlock x:Name="lblZoomLevel" Text="100%"
                                   Foreground="#A0A0B0" FontSize="12"
                                   VerticalAlignment="Center" Width="42"/>

                        <Button Content="↺" Click="ZoomReset_Click"
                                Style="{StaticResource ActionBtn}"
                                Width="28" Height="28" Padding="0"
                                FontSize="14" ToolTip="Reset 100%"/>
                    </StackPanel>
                </Border>

                <!-- CANVAS -->
                <ScrollViewer x:Name="designScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                    <Border x:Name="canvasScaleContainer" Padding="30" HorizontalAlignment="Center">
                        <Border.LayoutTransform>
                            <ScaleTransform x:Name="canvasScale" ScaleX="1" ScaleY="1"/>
                        </Border.LayoutTransform>
                        <!-- shadow effect -->
                        <Border>
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="30"
                                                  ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <Border Background="White" CornerRadius="4">
                                <Canvas x:Name="DesignCanvas"
                                        Width="380" Height="3000"
                                        Background="White"
                                        AllowDrop="True"
                                        Drop="Canvas_Drop"
                                        MouseLeftButtonDown="Canvas_MouseDown"
                                        MouseMove="Canvas_MouseMove"
                                        MouseLeftButtonUp="Canvas_MouseUp"/>
                            </Border>
                        </Border>
                    </Border>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ═══ PROPERTIES ═══ -->
        <Border Grid.Column="2" Background="#13131A">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Padding="16,18,16,12"
                        BorderBrush="#1E1E28"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="◈" Foreground="#00BFFF" FontSize="14"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Properties" Foreground="White"
                                   FontSize="15" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <!-- Item type badge — thêm ngay sau Border header của Properties -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,10,14,14">

                        <!-- Item Badge — nằm inline đầu properties -->
                        <Border x:Name="selectedItemBadge"
                Padding="8,5"
                CornerRadius="5"
                Background="#1E1E22"
                BorderBrush="#2E2E35"
                BorderThickness="1"
                Margin="0,0,0,10"
                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="selectedItemIcon"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="12"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="selectedItemType"
                           Foreground="#E0E0E0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>



                        <TextBlock x:Name="lblValue"
                                   Text="VALUE" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="propValue"
                                 TextChanged="PropValue_TextChanged"
                                 PreviewTextInput="PropValue_PreviewTextInput"/>

                        <TextBlock x:Name="lblWidth"
                                   Text="WIDTH" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="propWidth"
                                 TextChanged="PropSize_TextChanged"
                                   PreviewTextInput="NumericOnly_PreviewTextInput"
                                   PreviewKeyDown="NumericOnly_PreviewKeyDown"
                                 DataObject.Pasting="NumericOnly_Pasting"/>

                        <TextBlock x:Name="lblHeight"
                                   Text="HEIGHT" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="propHeight"
                                 TextChanged="PropSize_TextChanged"
                                   PreviewTextInput="NumericOnly_PreviewTextInput"
                                   PreviewKeyDown="NumericOnly_PreviewKeyDown"
                                 DataObject.Pasting="NumericOnly_Pasting"/>

                        <TextBlock x:Name="lblFontSize"
                                   Text="FONT SIZE" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="propFontSize"
                                 TextChanged="FontPropertyChanged"
                                   PreviewTextInput="NumericOnly_PreviewTextInput"
                                 PreviewKeyDown="NumericOnly_PreviewKeyDown"
                                 DataObject.Pasting="NumericOnly_Pasting"/>

                        <!-- Bold / Italic row -->
                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox x:Name="chkBold" Content="Bold"
                                      IsThreeState="True"
                                      Checked="FontPropertyChanged"
                                      Unchecked="FontPropertyChanged"
                                      Indeterminate="FontPropertyChanged"
                                      Margin="0,0,16,0"/>
                            <CheckBox x:Name="chkItalic" Content="Italic"
                                      IsThreeState="True"
                                      Checked="FontPropertyChanged"
                                      Unchecked="FontPropertyChanged"
                                      Indeterminate="FontPropertyChanged"/>
                        </WrapPanel>

                        <!-- Divider -->
                        <Border Height="1" Background="#1E1E28" Margin="0,4,0,4"/>

                        <TextBlock x:Name="lblIndex" Text="INDEX" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="propIndex" TextChanged="PropIndex_TextChanged"
                                 Foreground="#FFFFFF"
                                  DataObject.Pasting="NumericOnly_Pasting"
                                   PreviewTextInput="NumericOnly_PreviewTextInput"
                                 PreviewKeyDown="NumericOnly_PreviewKeyDown"/>

                        <TextBlock x:Name="lblZone"
                                   Text="ZONE" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="propZone"
                                  SelectionChanged="PropZone_SelectionChanged">
                            <ComboBoxItem Content="Left"/>
                            <ComboBoxItem Content="Center"/>
                            <ComboBoxItem Content="Right"/>
                        </ComboBox>

                        <TextBlock x:Name="lblLineStyle"
                                   Text="LINE STYLE" Style="{StaticResource LabelStyle}"
                                   Visibility="Collapsed"/>
                        <ComboBox x:Name="propLineStyle"
                                  Visibility="Collapsed"
                                  SelectionChanged="PropLineStyle_SelectionChanged">
                            <ComboBoxItem Content="Solid"/>
                            <ComboBoxItem Content="Dashed"/>
                            <ComboBoxItem Content="Dotted"/>
                            <ComboBoxItem Content="DashDot"/>
                        </ComboBox>

                        <TextBlock x:Name="lblTextPosition"
                                   Text="TEXT POSITION" Style="{StaticResource LabelStyle}"
                                   Visibility="Collapsed"/>
                        <ComboBox x:Name="propTextPosition"
                                  Visibility="Collapsed"
                                  SelectionChanged="PropTextPosition_SelectionChanged">
                            <ComboBoxItem Content="Top"/>
                            <ComboBoxItem Content="Middle"/>
                            <ComboBoxItem Content="Bottom"/>
                        </ComboBox>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

    </Grid>
</Window>